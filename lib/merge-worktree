#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/git-worktree-common
source "$SCRIPT_DIR/git-worktree-common"

usage() {
    cat << EOF
Usage: git-merge-worktree <source-ref> <destination-branch>

Merge a source ref into the active worktree of a destination branch.

Source refs may be:
  - local branch
  - remote branch
  - tag
  - commit SHA

Examples:
  git-merge-worktree feat/chart feat/dashboard
  git-merge-worktree refs/remotes/origin/develop feat/my-feature
  git-merge-worktree refs/tags/v1.2.3 feat/my-feature

EOF
    exit 1
}

if [[ $# -ne 2 ]]; then
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
        usage
    fi
    print_error "Incorrect number of arguments"
    usage
fi

SOURCE_INPUT="$1"
DEST_BRANCH="$2"

print_status "Validating repository..."
validate_repository

DEFAULT_REMOTE="$(detect_default_remote || true)"
if [[ -z "$DEFAULT_REMOTE" ]]; then
    print_error "No git remote configured in the repository"
    exit 1
fi

REMOTE_URL="$(git -C "$REPO_ROOT" config --get "remote.$DEFAULT_REMOTE.url" 2>/dev/null || true)"
if [[ -z "$REMOTE_URL" ]]; then
    print_error "Remote '$DEFAULT_REMOTE' has no URL configured"
    exit 1
fi

print_status "Remote $DEFAULT_REMOTE: $REMOTE_URL"
print_status "Fetching latest from remote $DEFAULT_REMOTE..."
if fetch_remote_branches "$DEFAULT_REMOTE" 2>&1 | tail -1; then
    print_success "Fetch completed"
else
    print_error "Failed to fetch from remote '$DEFAULT_REMOTE'"
    exit 1
fi

IFS='|' read -r SOURCE_KIND SOURCE_REF SOURCE_COMMIT <<< "$(resolve_ref_kind "$SOURCE_INPUT" "$DEFAULT_REMOTE")"

if ! git -C "$REPO_ROOT" rev-parse --verify "$DEST_BRANCH" > /dev/null 2>&1; then
    print_error "Destination branch '$DEST_BRANCH' does not exist locally"
    exit 1
fi

DEST_WORKTREE="$(find_worktree_path_for_branch "$DEST_BRANCH" || true)"
if [[ -z "$DEST_WORKTREE" ]]; then
    DEST_WORKTREE="$(default_worktree_path_for_branch "$DEST_BRANCH")"
    if [[ -d "$DEST_WORKTREE" ]] && is_registered_worktree "$DEST_WORKTREE"; then
        CURRENT_BRANCH="$(git -C "$DEST_WORKTREE" symbolic-ref --short HEAD 2>/dev/null || true)"
        if [[ -z "$CURRENT_BRANCH" ]]; then
            print_error "Destination worktree is detached: $DEST_WORKTREE"
            exit 1
        fi
    fi

    print_error "Branch '$DEST_BRANCH' is not checked out in any worktree"
    exit 1
fi

if [[ ! -d "$DEST_WORKTREE" ]]; then
    print_warning "Destination worktree is registered but missing on disk: $DEST_WORKTREE"
    print_status "Pruning stale worktree registrations..."
    git -C "$REPO_ROOT" worktree prune --expire now
    if [[ ! -d "$DEST_WORKTREE" ]]; then
        print_error "Destination worktree no longer exists: $DEST_WORKTREE"
        exit 1
    fi
fi

CURRENT_BRANCH="$(git -C "$DEST_WORKTREE" symbolic-ref --short HEAD 2>/dev/null || true)"
if [[ -z "$CURRENT_BRANCH" ]]; then
    print_error "Destination worktree is detached: $DEST_WORKTREE"
    exit 1
fi

if [[ "$CURRENT_BRANCH" != "$DEST_BRANCH" ]]; then
    print_error "Destination worktree is not on branch '$DEST_BRANCH'"
    print_status "Current branch: $CURRENT_BRANCH"
    exit 1
fi

print_status "Destination worktree: $DEST_WORKTREE"
print_status "Destination branch: $DEST_BRANCH"
print_status "Resolved source ref: $SOURCE_REF"
print_status "Resolved source commit: $SOURCE_COMMIT"
print_status "Fetch performed: true"

if git -C "$DEST_WORKTREE" merge "$SOURCE_REF" -m "Merge $SOURCE_REF into $DEST_BRANCH"; then
    print_success "Merge completed successfully"
    print_status "Worktree location: $DEST_WORKTREE"
else
    print_error "Merge failed or has conflicts"
    print_status "Resolve conflicts in worktree: $DEST_WORKTREE"
    print_status "Then run: git -C '$DEST_WORKTREE' commit"
    print_status "Or abort: git -C '$DEST_WORKTREE' merge --abort"
    exit 1
fi
