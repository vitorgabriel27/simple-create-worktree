#!/bin/bash

# Git Worktree Update Script
# Fetches from remote and fast-forwards a target branch safely

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

if [[ -z "${REPO_ROOT:-}" ]]; then
    REPO_ROOT="$(pwd)"
fi

print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

usage() {
    cat << EOF
Usage: git-update-worktree [branch-name]

Update the current branch (default) or a specific local branch by fast-forwarding
from the default remote after fetching.

Arguments:
  [branch-name]      Optional local branch name to update explicitly

Examples:
  git-update-worktree
  git-update-worktree develop
  git-update-worktree feat/my-feature

EOF
    exit 1
}

detect_default_remote() {
    local current_branch
    local branch_remote
    local first_remote

    current_branch="$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null || true)"
    if [[ -n "$current_branch" ]]; then
        branch_remote="$(git -C "$REPO_ROOT" config --get "branch.$current_branch.remote" 2>/dev/null || true)"
        if [[ -n "$branch_remote" ]]; then
            echo "$branch_remote"
            return 0
        fi
    fi

    if git -C "$REPO_ROOT" remote | grep -qx "origin"; then
        echo "origin"
        return 0
    fi

    first_remote="$(git -C "$REPO_ROOT" remote | head -1)"
    if [[ -n "$first_remote" ]]; then
        echo "$first_remote"
        return 0
    fi

    return 1
}

find_worktree_path_for_branch() {
    local branch_name="$1"

    git -C "$REPO_ROOT" worktree list --porcelain | awk -v b="$branch_name" '
        $1 == "worktree" { wt = substr($0, 10) }
        $1 == "branch" {
            ref = substr($0, 8)
            if (ref == "refs/heads/" b) {
                print wt
                exit
            }
        }
    '
}

update_branch_fast_forward() {
    local branch_name="$1"
    local branch_upstream
    local remote_branch
    local active_worktree
    local local_sha
    local remote_sha

    if ! git -C "$REPO_ROOT" rev-parse --verify "$branch_name" > /dev/null 2>&1; then
        print_error "Local branch '$branch_name' does not exist"
        exit 1
    fi

    branch_upstream="$(git -C "$REPO_ROOT" for-each-ref --format='%(upstream:short)' "refs/heads/$branch_name" | head -1)"
    if [[ -n "$branch_upstream" ]]; then
        remote_branch="$branch_upstream"
    else
        remote_branch="$DEFAULT_REMOTE/$branch_name"
    fi

    if ! git -C "$REPO_ROOT" rev-parse --verify "$remote_branch" > /dev/null 2>&1; then
        print_error "Remote branch '$remote_branch' does not exist"
        exit 1
    fi

    active_worktree="$(find_worktree_path_for_branch "$branch_name" || true)"
    if [[ -n "$active_worktree" ]] && [[ -d "$active_worktree" ]]; then
        print_status "Updating '$branch_name' in worktree: $active_worktree"
        if git -C "$active_worktree" merge --ff-only "$remote_branch"; then
            print_success "Branch '$branch_name' updated successfully"
            return 0
        fi

        print_error "Failed to fast-forward '$branch_name' in worktree '$active_worktree'"
        exit 1
    fi

    if [[ -n "$active_worktree" ]] && [[ ! -d "$active_worktree" ]]; then
        print_warning "Found stale worktree registration for '$branch_name' at '$active_worktree'"
        print_status "Pruning stale worktree registrations..."
        git -C "$REPO_ROOT" worktree prune --expire now
    fi

    local_sha="$(git -C "$REPO_ROOT" rev-parse "$branch_name")"
    remote_sha="$(git -C "$REPO_ROOT" rev-parse "$remote_branch")"

    if [[ "$local_sha" == "$remote_sha" ]]; then
        print_success "Branch '$branch_name' is already up to date"
        return 0
    fi

    if git -C "$REPO_ROOT" merge-base --is-ancestor "$local_sha" "$remote_sha"; then
        git -C "$REPO_ROOT" update-ref "refs/heads/$branch_name" "$remote_sha" "$local_sha"
        print_success "Fast-forwarded '$branch_name' to '$remote_branch'"
        return 0
    fi

    print_error "Cannot fast-forward '$branch_name' to '$remote_branch' (branches diverged)"
    print_status "Switch to that branch and reconcile manually (merge or rebase)."
    exit 1
}

if [[ $# -gt 1 ]]; then
    print_error "Too many arguments"
    usage
fi

TARGET_BRANCH="${1:-}"

if [[ "$TARGET_BRANCH" == "-h" ]] || [[ "$TARGET_BRANCH" == "--help" ]]; then
    usage
fi

print_status "Validating repository..."
if ! git -C "$REPO_ROOT" rev-parse --git-dir > /dev/null 2>&1; then
    print_error "Not a valid git repository at $REPO_ROOT"
    exit 1
fi

DEFAULT_REMOTE="$(detect_default_remote || true)"
if [[ -z "$DEFAULT_REMOTE" ]]; then
    print_error "No git remote configured in the repository"
    exit 1
fi

REMOTE_URL="$(git -C "$REPO_ROOT" config --get "remote.$DEFAULT_REMOTE.url" 2>/dev/null || true)"
if [[ -z "$REMOTE_URL" ]]; then
    print_error "Remote '$DEFAULT_REMOTE' has no URL configured"
    exit 1
fi

print_status "Remote $DEFAULT_REMOTE: $REMOTE_URL"
print_status "Fetching latest from remote $DEFAULT_REMOTE..."
if git -C "$REPO_ROOT" fetch "$DEFAULT_REMOTE" 2>&1 | tail -1; then
    print_success "Fetch completed"
else
    print_error "Failed to fetch from remote '$DEFAULT_REMOTE'"
    exit 1
fi

if [[ -z "$TARGET_BRANCH" ]]; then
    INV_DIR="${INVOCATION_DIR:-$REPO_ROOT}"
    TARGET_BRANCH="$(git -C "$INV_DIR" symbolic-ref --short HEAD 2>/dev/null || true)"

    if [[ -z "$TARGET_BRANCH" ]]; then
        print_warning "Detached HEAD detected - fetch completed, no branch updated"
        print_status "Pass a branch name explicitly: git-update-worktree <branch>"
        exit 0
    fi
fi

print_status "Target branch: $TARGET_BRANCH"
update_branch_fast_forward "$TARGET_BRANCH"
