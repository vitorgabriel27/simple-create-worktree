#!/bin/bash

# Global Git Worktree Removal Script
# Auto-detects a Git repository by searching up the directory tree.

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

print_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

usage() {
    cat << EOF
Usage: $(basename "$0") <branch-name-or-path>

Examples:
  $(basename "$0") feat/my-feature
  $(basename "$0") /path/to/worktree
EOF
    exit 1
}

# Resolve script directory even when called through a symlink.
resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    while [[ -L "$source" ]]; do
        local dir
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        source="$(readlink "$source")"
        [[ "$source" != /* ]] && source="$dir/$source"
    done
    cd -P "$(dirname "$source")" && pwd
}

# Function to find a git repository by searching up
find_git_repo() {
    local current_dir="$(pwd)"

    while [[ "$current_dir" != "/" ]]; do
        # Candidate 1: we're inside a worktree attached to a bare repository.
        local common_dir
        common_dir="$(git -C "$current_dir" rev-parse --git-common-dir 2>/dev/null || true)"
        if [[ -n "$common_dir" ]]; then
            if [[ "$common_dir" != /* ]]; then
                common_dir="$current_dir/$common_dir"
            fi

            common_dir="$(cd "$common_dir" 2>/dev/null && pwd || true)"
            if [[ -n "$common_dir" ]]; then
                if git -C "$common_dir" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
                    echo "$common_dir"
                    return 0
                fi

                local candidate
                if [[ "$(basename "$common_dir")" == ".git" ]]; then
                    candidate="$(dirname "$common_dir")"
                else
                    candidate="$(dirname "$common_dir")"
                fi
                if git -C "$candidate" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
                    echo "$candidate"
                    return 0
                fi
            fi
        fi

        # Candidate 2: current directory is a git repository root.
        local toplevel
        toplevel="$(git -C "$current_dir" rev-parse --show-toplevel 2>/dev/null || true)"
        if [[ -n "$toplevel" ]]; then
            echo "$toplevel"
            return 0
        fi

        # Candidate 3: current directory is a bare repository.
        if git -C "$current_dir" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
            echo "$current_dir"
            return 0
        fi

        current_dir="$(dirname "$current_dir")"
    done

    print_error "No git repository found in parent directories"
    print_status "Current working directory: $(pwd)"
    print_status "Please run this command from within a git repository"
    return 1
}

# Validate arguments
if [[ $# -lt 1 ]]; then
    usage
fi

BRANCH_OR_PATH="$1"

# Resolve project paths
SCRIPT_DIR="$(resolve_script_dir)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CORE_SCRIPT="$PROJECT_ROOT/lib/remove-worktree"

if [[ ! -x "$CORE_SCRIPT" ]]; then
    print_error "Core script not found or not executable: $CORE_SCRIPT"
    exit 1
fi

# Help should work even when not inside a repository.
if [[ "$BRANCH_OR_PATH" == "-h" ]] || [[ "$BRANCH_OR_PATH" == "--help" ]]; then
    exec "$CORE_SCRIPT" "$BRANCH_OR_PATH"
fi

# Find the repository
print_status "Searching for git repository..."
REPO_ROOT=$(find_git_repo) || exit 1

print_status "Found repository at: $REPO_ROOT"

# Run the core remove-worktree script with the repo as working directory
print_status "Running remove-worktree..."
cd "$REPO_ROOT"
# Set REPO_ROOT environment variable for the script
export REPO_ROOT
exec "$CORE_SCRIPT" "$BRANCH_OR_PATH"
