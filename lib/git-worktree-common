#!/bin/bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

ensure_repo_root() {
    if [[ -z "${REPO_ROOT:-}" ]]; then
        REPO_ROOT="$(pwd)"
    fi
}

validate_repository() {
    ensure_repo_root
    if ! git -C "$REPO_ROOT" rev-parse --git-dir > /dev/null 2>&1; then
        print_error "Not a valid git repository at $REPO_ROOT"
        exit 1
    fi
}

detect_default_remote() {
    local current_branch
    local branch_remote
    local first_remote

    current_branch="$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null || true)"
    if [[ -n "$current_branch" ]]; then
        branch_remote="$(git -C "$REPO_ROOT" config --get "branch.$current_branch.remote" 2>/dev/null || true)"
        if [[ -n "$branch_remote" ]]; then
            printf '%s\n' "$branch_remote"
            return 0
        fi
    fi

    if git -C "$REPO_ROOT" remote | grep -qx "origin"; then
        printf 'origin\n'
        return 0
    fi

    first_remote="$(git -C "$REPO_ROOT" remote | head -1)"
    if [[ -n "$first_remote" ]]; then
        printf '%s\n' "$first_remote"
        return 0
    fi

    return 1
}

fetch_remote_branches() {
    local remote_name="$1"

    git -C "$REPO_ROOT" fetch "$remote_name" \
        "+refs/heads/*:refs/remotes/$remote_name/*" \
        --prune
}

normalize_existing_path() {
    local path="$1"

    if [[ -d "$path" ]]; then
        (cd "$path" && pwd)
        return 0
    fi

    if [[ -e "$path" ]]; then
        local parent
        parent="$(cd "$(dirname "$path")" && pwd)"
        printf '%s/%s\n' "$parent" "$(basename "$path")"
        return 0
    fi

    return 1
}

is_registered_worktree() {
    local path="$1"
    git -C "$REPO_ROOT" worktree list --porcelain | grep -Fxq "worktree $path"
}

find_worktree_path_for_branch() {
    local branch_name="$1"

    git -C "$REPO_ROOT" worktree list --porcelain | awk -v b="$branch_name" '
        $1 == "worktree" { wt = substr($0, 10) }
        $1 == "branch" {
            ref = substr($0, 8)
            if (ref == "refs/heads/" b) {
                print wt
                exit
            }
        }
    '
}

branch_for_worktree_path() {
    local worktree_path="$1"

    git -C "$REPO_ROOT" worktree list --porcelain | awk -v wt="$worktree_path" '
        $1 == "worktree" { current = substr($0, 10) }
        $1 == "branch" && current == wt {
            ref = substr($0, 8)
            sub(/^refs\/heads\//, "", ref)
            print ref
            exit
        }
    '
}

worktree_is_detached() {
    local worktree_path="$1"
    [[ -z "$(branch_for_worktree_path "$worktree_path")" ]]
}

current_worktree_or_empty() {
    local dir="$1"
    git -C "$dir" rev-parse --show-toplevel 2>/dev/null || true
}

default_worktree_path_for_branch() {
    local branch_name="$1"

    if [[ "$branch_name" == */* ]]; then
        printf '%s/%s/%s\n' "$REPO_ROOT" "${branch_name%%/*}" "${branch_name#*/}"
    else
        printf '%s/%s\n' "$REPO_ROOT" "$branch_name"
    fi
}

resolve_ref_kind() {
    local input_ref="$1"
    local remote_name="$2"
    local -a matches=()
    local kind=""
    local full_ref=""
    local commit=""

    if [[ "$input_ref" == refs/heads/* ]]; then
        if git -C "$REPO_ROOT" rev-parse --verify "$input_ref" > /dev/null 2>&1; then
            kind="local-branch"
            full_ref="$input_ref"
        else
            print_error "Local branch '$input_ref' does not exist"
            return 1
        fi
    elif [[ "$input_ref" == refs/remotes/* ]]; then
        if git -C "$REPO_ROOT" rev-parse --verify "$input_ref" > /dev/null 2>&1; then
            kind="remote-branch"
            full_ref="$input_ref"
        else
            print_error "Remote branch '$input_ref' does not exist"
            return 1
        fi
    elif [[ "$input_ref" == refs/tags/* ]]; then
        if git -C "$REPO_ROOT" rev-parse --verify "$input_ref" > /dev/null 2>&1; then
            kind="tag"
            full_ref="$input_ref"
        else
            print_error "Tag '$input_ref' does not exist"
            return 1
        fi
    elif [[ "$input_ref" == */* ]] && git -C "$REPO_ROOT" show-ref --verify --quiet "refs/remotes/$input_ref"; then
        kind="remote-branch"
        full_ref="refs/remotes/$input_ref"
    else
        if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$input_ref"; then
            matches+=("local-branch:refs/heads/$input_ref")
        fi

        if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/remotes/$remote_name/$input_ref"; then
            matches+=("remote-branch:refs/remotes/$remote_name/$input_ref")
        fi

        if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/tags/$input_ref"; then
            matches+=("tag:refs/tags/$input_ref")
        fi

        if [[ "${#matches[@]}" -eq 0 || "$input_ref" =~ ^[0-9a-fA-F]{7,40}$ || "$input_ref" == *^* || "$input_ref" == *~* ]]; then
            if git -C "$REPO_ROOT" rev-parse --verify "${input_ref}^{commit}" > /dev/null 2>&1; then
                commit="$(git -C "$REPO_ROOT" rev-parse --verify "${input_ref}^{commit}")"
                matches+=("commit:$commit")
            fi
        fi

        if [[ "${#matches[@]}" -eq 0 ]]; then
            print_error "Could not resolve ref '$input_ref'"
            return 1
        fi

        if [[ "${#matches[@]}" -gt 1 ]]; then
            print_error "Ref '$input_ref' is ambiguous"
            print_status "Use a fully qualified ref such as refs/heads/<name>, refs/remotes/$remote_name/<name>, refs/tags/<name>, or a full commit SHA."
            return 1
        fi

        kind="${matches[0]%%:*}"
        full_ref="${matches[0]#*:}"
    fi

    commit="$(git -C "$REPO_ROOT" rev-parse --verify "${full_ref}^{commit}")"
    printf '%s|%s|%s\n' "$kind" "$full_ref" "$commit"
}
