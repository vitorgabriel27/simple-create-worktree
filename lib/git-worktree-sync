#!/bin/bash

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

declare -a SYNC_ENV_MAPPINGS=()
declare -a SYNC_SHARED_PATH_MAPPINGS=()
declare -a SYNC_POETRY_PROJECTS=()
declare -a SYNC_NODE_PROJECTS=()
SYNC_DISABLE_POETRY_DISCOVERY=0
SYNC_DISABLE_NODE_DISCOVERY=0

print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

usage() {
    cat << EOF
Usage: git-worktree-sync [worktree-path]

Synchronize a worktree with shared runtime assets stored in the bare repository.

Behavior:
  - If a worktree path is provided, synchronize that worktree
  - If run inside a worktree, synchronize the current worktree
  - If run from the bare repository root with no argument, synchronize all linked worktrees

Environment variables:
  WORKTREE_SYNC_SKIP_INSTALL=1   Skip Poetry and pnpm installs

Optional repo config:
  <bare-root>/.worktree-sync.sh  Bash file defining:
    SYNC_ENV_MAPPINGS=("local|shared|fallback")
    SYNC_SHARED_PATH_MAPPINGS=("local|shared|dir" "other/path|other/shared/file|file")
    SYNC_POETRY_PROJECTS=("path/to/project")
    SYNC_NODE_PROJECTS=("path/to/app")
    SYNC_DISABLE_POETRY_DISCOVERY=1
    SYNC_DISABLE_NODE_DISCOVERY=1

EOF
    exit 1
}

resolve_abs_path() {
    local path="$1"

    if [[ -d "$path" ]]; then
        (cd "$path" && pwd)
        return 0
    fi

    if [[ -e "$path" ]]; then
        local parent
        parent="$(cd "$(dirname "$path")" && pwd)"
        printf '%s/%s\n' "$parent" "$(basename "$path")"
        return 0
    fi

    return 1
}

get_git_common_dir() {
    local dir="$1"
    local common_dir

    common_dir="$(git -C "$dir" rev-parse --git-common-dir 2>/dev/null || true)"
    if [[ -z "$common_dir" ]]; then
        return 1
    fi

    if [[ "$common_dir" != /* ]]; then
        common_dir="$(cd "$dir/$common_dir" 2>/dev/null && pwd || true)"
    else
        common_dir="$(cd "$common_dir" 2>/dev/null && pwd || true)"
    fi

    [[ -n "$common_dir" ]] || return 1
    printf '%s\n' "$common_dir"
}

find_bare_root() {
    local dir="$1"
    local common_dir
    local candidate

    if git -C "$dir" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
        (cd "$dir" && pwd)
        return 0
    fi

    common_dir="$(get_git_common_dir "$dir" || true)"
    if [[ -n "$common_dir" ]] && git -C "$common_dir" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
        printf '%s\n' "$common_dir"
        return 0
    fi

    candidate="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "$candidate" ]]; then
        common_dir="$(get_git_common_dir "$candidate" || true)"
        if [[ -n "$common_dir" ]] && git -C "$common_dir" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
            printf '%s\n' "$common_dir"
            return 0
        fi
    fi

    return 1
}

current_worktree_or_empty() {
    local dir="$1"
    git -C "$dir" rev-parse --show-toplevel 2>/dev/null || true
}

ensure_dir() {
    mkdir -p "$1"
}

backup_local_file() {
    local path="$1"
    local suffix

    suffix="$(date +%Y%m%d%H%M%S)"
    mv "$path" "${path}.pre-shared-${suffix}"
}

sanitize_path_component() {
    local value="$1"
    value="${value//\//__}"
    value="${value// /_}"
    printf '%s\n' "$value"
}

is_excluded_path() {
    local rel="$1"

    case "$rel" in
        .git/*|*/.git/*|.venv/*|*/.venv/*|node_modules/*|*/node_modules/*|.next/*|*/.next/*|dist/*|*/dist/*|build/*|*/build/*|coverage/*|*/coverage/*|htmlcov/*|*/htmlcov/*|__pycache__/*|*/__pycache__/*)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

load_repo_config() {
    local bare_root="$1"
    local config_file="$bare_root/.worktree-sync.sh"

    SYNC_ENV_MAPPINGS=()
    SYNC_SHARED_PATH_MAPPINGS=()
    SYNC_POETRY_PROJECTS=()
    SYNC_NODE_PROJECTS=()
    SYNC_DISABLE_POETRY_DISCOVERY=0
    SYNC_DISABLE_NODE_DISCOVERY=0

    if [[ -f "$config_file" ]]; then
        # shellcheck disable=SC1090
        source "$config_file"
        print_status "Loaded repo sync config: $config_file"
    fi
}

ensure_shared_runtime_path() {
    local worktree_path="$1"
    local bare_root="$2"
    local runtime_rel="$3"
    local shared_rel="$4"
    local path_type="${5:-}"
    local local_path="$worktree_path/$runtime_rel"
    local shared_path="$bare_root/shared/$shared_rel"

    if [[ -z "$path_type" ]]; then
        if [[ -d "$local_path" ]]; then
            path_type="dir"
        else
            path_type="file"
        fi
    fi

    ensure_dir "$(dirname "$shared_path")"

    if [[ -L "$local_path" ]]; then
        local target
        target="$(readlink "$local_path")"
        if [[ "$target" == "$shared_path" ]]; then
            if [[ "$path_type" == "dir" ]]; then
                ensure_dir "$shared_path"
            elif [[ ! -e "$shared_path" ]]; then
                : > "$shared_path"
            fi
            return 0
        fi
    fi

    if [[ ! -e "$shared_path" ]]; then
        if [[ -e "$local_path" && ! -L "$local_path" ]]; then
            mv "$local_path" "$shared_path"
            print_status "Moved $runtime_rel into shared storage"
        elif [[ "$path_type" == "dir" ]]; then
            ensure_dir "$shared_path"
            print_status "Created shared directory: $shared_path"
        else
            : > "$shared_path"
            print_status "Created shared file: $shared_path"
        fi
    elif [[ -e "$local_path" && ! -L "$local_path" ]]; then
        backup_local_file "$local_path"
        print_warning "Preserved existing local path backup for $runtime_rel"
    fi

    ensure_dir "$(dirname "$local_path")"
    ln -sfn "$shared_path" "$local_path"
    print_success "Linked shared path $runtime_rel"
}

link_shared_runtime_paths() {
    local worktree_path="$1"
    local bare_root="$2"
    local mapping
    local local_rel
    local shared_rel
    local path_type

    [[ "${#SYNC_SHARED_PATH_MAPPINGS[@]}" -gt 0 ]] || return 0

    for mapping in "${SYNC_SHARED_PATH_MAPPINGS[@]}"; do
        IFS='|' read -r local_rel shared_rel path_type <<< "$mapping"
        ensure_shared_runtime_path "$worktree_path" "$bare_root" "$local_rel" "$shared_rel" "$path_type"
    done
}

discover_env_mappings() {
    local worktree_path="$1"
    declare -A seen=()
    local abs_path
    local rel_path
    local runtime_rel
    local fallback_rel
    local dir_rel
    local basename
    local shared_rel

    while IFS= read -r abs_path; do
        rel_path="${abs_path#$worktree_path/}"
        if is_excluded_path "$rel_path"; then
            continue
        fi

        dir_rel="$(dirname "$rel_path")"
        [[ "$dir_rel" == "." ]] && dir_rel=""
        basename="$(basename "$rel_path")"
        fallback_rel=""

        case "$basename" in
            .env.sample|.env.example)
                runtime_rel="${dir_rel:+$dir_rel/}.env"
                fallback_rel="$rel_path"
                ;;
            .env.*.sample)
                runtime_rel="${dir_rel:+$dir_rel/}${basename%.sample}"
                fallback_rel="$rel_path"
                ;;
            .env.*.example)
                runtime_rel="${dir_rel:+$dir_rel/}${basename%.example}"
                fallback_rel="$rel_path"
                ;;
            .env|.env.*)
                runtime_rel="$rel_path"
                ;;
            *)
                continue
                ;;
        esac

        if [[ -n "${seen[$runtime_rel]:-}" ]]; then
            continue
        fi
        seen["$runtime_rel"]=1

        if [[ -n "$dir_rel" ]]; then
            shared_rel="$dir_rel/$(basename "$runtime_rel")"
        else
            shared_rel="root/$(basename "$runtime_rel")"
        fi

        printf '%s|%s|%s\n' "$runtime_rel" "$shared_rel" "$fallback_rel"
    done < <(
        find "$worktree_path" \
            \( -type d \( -name .git -o -name .venv -o -name node_modules -o -name .next -o -name dist -o -name build -o -name coverage -o -name htmlcov -o -name __pycache__ \) -prune \) \
            -o \( -type f \( -name '.env' -o -name '.env.*' -o -name '.env.sample' -o -name '.env.example' -o -name '.env.*.sample' -o -name '.env.*.example' \) -print \) \
            | sort
    )
}

ensure_shared_file() {
    local worktree_path="$1"
    local bare_root="$2"
    local runtime_rel="$3"
    local shared_rel="$4"
    local fallback_rel="${5:-}"
    local local_path="$worktree_path/$runtime_rel"
    local shared_path="$bare_root/shared/env/$shared_rel"
    local fallback_path=""

    if [[ -n "$fallback_rel" ]]; then
        fallback_path="$worktree_path/$fallback_rel"
    fi

    ensure_dir "$(dirname "$shared_path")"

    if [[ ! -e "$shared_path" ]]; then
        if [[ -f "$local_path" && ! -L "$local_path" ]]; then
            cp "$local_path" "$shared_path"
            print_status "Seeded shared file from $runtime_rel"
        elif [[ -n "$fallback_path" && -f "$fallback_path" ]]; then
            cp "$fallback_path" "$shared_path"
            print_status "Seeded shared file from $fallback_rel"
        else
            : > "$shared_path"
            print_warning "Created empty shared file: $shared_path"
        fi
    fi

    ensure_dir "$(dirname "$local_path")"

    if [[ -e "$local_path" || -L "$local_path" ]]; then
        if [[ -L "$local_path" ]]; then
            local target
            target="$(readlink "$local_path")"
            if [[ "$target" == "$shared_path" ]]; then
                return 0
            fi
        fi
        backup_local_file "$local_path"
    fi

    ln -sfn "$shared_path" "$local_path"
    print_success "Linked $runtime_rel"
}

link_envs() {
    local worktree_path="$1"
    local bare_root="$2"
    local mapping
    local local_rel
    local shared_rel
    local fallback_rel

    ensure_dir "$bare_root/shared/env"

    if [[ "${#SYNC_ENV_MAPPINGS[@]}" -gt 0 ]]; then
        for mapping in "${SYNC_ENV_MAPPINGS[@]}"; do
            IFS='|' read -r local_rel shared_rel fallback_rel <<< "$mapping"
            ensure_shared_file "$worktree_path" "$bare_root" "$local_rel" "$shared_rel" "$fallback_rel"
        done
        return 0
    fi

    while IFS= read -r mapping; do
        IFS='|' read -r local_rel shared_rel fallback_rel <<< "$mapping"
        ensure_shared_file "$worktree_path" "$bare_root" "$local_rel" "$shared_rel" "$fallback_rel"
    done < <(discover_env_mappings "$worktree_path")
}

discover_poetry_projects() {
    local worktree_path="$1"
    local abs_path
    local rel_dir

    while IFS= read -r abs_path; do
        rel_dir="$(dirname "${abs_path#$worktree_path/}")"
        printf '%s\n' "$rel_dir"
    done < <(
        find "$worktree_path" \
            \( -type d \( -name .git -o -name .venv -o -name node_modules -o -name .next -o -name dist -o -name build -o -name coverage -o -name htmlcov -o -name __pycache__ \) -prune \) \
            -o \( -type f -name 'pyproject.toml' -print \) \
            | sort
    )
}

extract_python_constraint() {
    local pyproject_path="$1"

    awk '
        /^\[tool\.poetry\.dependencies\]/ { in_deps=1; next }
        /^\[/ { if (in_deps) exit }
        in_deps && $1 == "python" {
            line=$0
            sub(/^[^=]*=/, "", line)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", line)
            gsub(/"/, "", line)
            print line
            exit
        }
    ' "$pyproject_path"
}

compare_version_keys() {
    local version="$1"
    local major="${version%%.*}"
    local minor="${version##*.}"
    printf '%04d%04d\n' "$major" "$minor"
}

constraint_matches() {
    local version="$1"
    local constraint_raw="$2"
    local version_key
    local part
    local bound
    local bound_key
    local major
    local lower

    version_key="$(compare_version_keys "$version")"
    constraint_raw="${constraint_raw// /}"

    if [[ -z "$constraint_raw" ]]; then
        return 0
    fi

    if [[ "$constraint_raw" == ^* ]]; then
        lower="${constraint_raw#^}"
        major="${lower%%.*}"
        bound_key="$(compare_version_keys "$lower")"
        [[ "$version_key" < "$bound_key" ]] && return 1
        [[ "${version%%.*}" != "$major" ]] && return 1
        return 0
    fi

    IFS=',' read -ra parts <<< "$constraint_raw"
    for part in "${parts[@]}"; do
        if [[ "$part" == \>=* ]]; then
            bound="${part#>=}"
            bound_key="$(compare_version_keys "$bound")"
            [[ "$version_key" < "$bound_key" ]] && return 1
        elif [[ "$part" == \>* ]]; then
            bound="${part#>}"
            bound_key="$(compare_version_keys "$bound")"
            [[ "$version_key" < "$bound_key" || "$version_key" == "$bound_key" ]] && return 1
        elif [[ "$part" == \<\=* ]]; then
            bound="${part#<=}"
            bound_key="$(compare_version_keys "$bound")"
            [[ "$version_key" > "$bound_key" ]] && return 1
        elif [[ "$part" == \<* ]]; then
            bound="${part#<}"
            bound_key="$(compare_version_keys "$bound")"
            [[ "$version_key" > "$bound_key" || "$version_key" == "$bound_key" ]] && return 1
        fi
    done

    return 0
}

detect_python_bin_for_project() {
    local pyproject_path="$1"
    local constraint
    local candidate
    local version
    local -a candidates=()
    declare -A seen=()
    local pyenv_root="${PYENV_ROOT:-$HOME/.pyenv}"

    constraint="$(extract_python_constraint "$pyproject_path" || true)"

    for candidate_name in python3.11 python3.10 python3.12 python3.13 python3.9 python3 python; do
        if command -v "$candidate_name" > /dev/null 2>&1; then
            candidate="$(command -v "$candidate_name")"
            if [[ -z "${seen[$candidate]:-}" ]]; then
                seen["$candidate"]=1
                candidates+=("$candidate")
            fi
        fi

        if [[ -d "$pyenv_root/versions" ]]; then
            while IFS= read -r pyenv_candidate; do
                [[ -x "$pyenv_candidate" ]] || continue
                if [[ -z "${seen[$pyenv_candidate]:-}" ]]; then
                    seen["$pyenv_candidate"]=1
                    candidates+=("$pyenv_candidate")
                fi
            done < <(find "$pyenv_root/versions" -path "*/bin/$candidate_name" \( -type f -o -type l \) 2>/dev/null | sort -r)
        fi
    done

    for candidate in "${candidates[@]}"; do
        version="$("$candidate" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null || true)"
        [[ -n "$version" ]] || continue
        if constraint_matches "$version" "$constraint"; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

python_major_minor() {
    local python_bin="$1"
    "$python_bin" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")'
}

read_env_value() {
    local file_path="$1"
    local key="$2"

    [[ -f "$file_path" ]] || return 1

    python3.11 - "$file_path" "$key" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
target = sys.argv[2]

for line in path.read_text().splitlines():
    stripped = line.strip()
    if not stripped or stripped.startswith("#") or "=" not in line:
        continue
    key, value = line.split("=", 1)
    if key.strip() != target:
        continue
    value = value.strip().strip('"').strip("'")
    print(value)
    raise SystemExit(0)

raise SystemExit(1)
PY
}

setup_poetry_auth() {
    local worktree_path="$1"
    local project_dir="$2"
    local project_rel="$3"
    local gitlab_token=""

    gitlab_token="${GITLAB_PKG_TOKEN:-}"
    if [[ -z "$gitlab_token" ]]; then
        gitlab_token="$(read_env_value "$project_dir/.env" "GITLAB_PKG_TOKEN" || true)"
    fi
    if [[ -z "$gitlab_token" ]]; then
        gitlab_token="$(read_env_value "$worktree_path/.env" "GITLAB_PKG_TOKEN" || true)"
    fi

    if [[ -z "$gitlab_token" ]]; then
        return 0
    fi

    export GITLAB_PKG_TOKEN="$gitlab_token"
    export POETRY_HTTP_BASIC_GITLAB_USERNAME="__token__"
    export POETRY_HTTP_BASIC_GITLAB_PASSWORD="$gitlab_token"
    export POETRY_HTTP_BASIC_GITLAB_KEYCLOAK_ADAPTER_USERNAME="__token__"
    export POETRY_HTTP_BASIC_GITLAB_KEYCLOAK_ADAPTER_PASSWORD="$gitlab_token"
    export POETRY_HTTP_BASIC_GITLAB_AGENTS_USERNAME="__token__"
    export POETRY_HTTP_BASIC_GITLAB_AGENTS_PASSWORD="$gitlab_token"

    print_status "Configured Poetry auth for $project_rel from shared env"
}

hash_file() {
    local path="$1"
    sha256sum "$path" | awk '{print substr($1, 1, 12)}'
}

sync_poetry_project() {
    local worktree_path="$1"
    local bare_root="$2"
    local project_rel="$3"
    local project_dir="$worktree_path/$project_rel"
    local pyproject_path="$project_dir/pyproject.toml"
    local lock_path
    local python_bin
    local python_mm
    local lock_hash
    local venv_dir
    local safe_rel

    [[ -f "$pyproject_path" ]] || return 0
    lock_path="$project_dir/poetry.lock"
    [[ -f "$lock_path" ]] || lock_path="$pyproject_path"

    python_bin="$(detect_python_bin_for_project "$pyproject_path" || true)"
    if [[ -z "$python_bin" ]]; then
        print_warning "No compatible Python found for $project_rel. Skipping."
        return 0
    fi

    python_mm="$(python_major_minor "$python_bin")"
    lock_hash="$(hash_file "$lock_path")"
    safe_rel="$(sanitize_path_component "$project_rel")"
    venv_dir="$bare_root/shared/venv/$safe_rel/py${python_mm}-${lock_hash}"

    ensure_dir "$(dirname "$venv_dir")"

    if [[ ! -x "$venv_dir/bin/python" ]]; then
        print_status "Creating shared venv for $project_rel: $venv_dir"
        if ! "$python_bin" -m venv "$venv_dir"; then
            print_warning "Failed to create venv for $project_rel with $python_bin. Skipping."
            rm -rf "$venv_dir"
            return 0
        fi
    else
        print_status "Reusing shared venv for $project_rel: $venv_dir"
    fi

    ln -sfn "$venv_dir" "$project_dir/.venv"
    print_success "Linked $project_rel/.venv"

    if [[ "${WORKTREE_SYNC_SKIP_INSTALL:-0}" == "1" ]]; then
        print_warning "Skipping Poetry install in $project_rel because WORKTREE_SYNC_SKIP_INSTALL=1"
        return 0
    fi

    if ! command -v poetry > /dev/null 2>&1; then
        print_warning "Poetry not found. Linked venv for $project_rel, but dependencies were not installed."
        return 0
    fi

    print_status "Installing Poetry dependencies in $project_rel"
    (
        cd "$project_dir"
        export VIRTUAL_ENV="$venv_dir"
        export PATH="$venv_dir/bin:$PATH"
        export POETRY_VIRTUALENVS_CREATE=false
        setup_poetry_auth "$worktree_path" "$project_dir" "$project_rel"
        if ! poetry install --no-interaction; then
            print_warning "Retrying $project_rel with --no-root"
            if ! poetry install --no-interaction --no-root; then
                print_warning "Poetry install failed for $project_rel. The shared venv remains linked, but dependencies may be incomplete."
            fi
        fi
    )
}

sync_poetry_projects() {
    local worktree_path="$1"
    local bare_root="$2"
    local project_rel

    if [[ "${#SYNC_POETRY_PROJECTS[@]}" -gt 0 ]]; then
        for project_rel in "${SYNC_POETRY_PROJECTS[@]}"; do
            sync_poetry_project "$worktree_path" "$bare_root" "$project_rel"
        done
        return 0
    fi

    if [[ "$SYNC_DISABLE_POETRY_DISCOVERY" == "1" ]]; then
        return 0
    fi

    while IFS= read -r project_rel; do
        [[ -n "$project_rel" ]] || continue
        sync_poetry_project "$worktree_path" "$bare_root" "$project_rel"
    done < <(discover_poetry_projects "$worktree_path")
}

detect_pnpm_cmd() {
    if command -v pnpm > /dev/null 2>&1; then
        command -v pnpm
        return 0
    fi

    if command -v corepack > /dev/null 2>&1 && command -v node > /dev/null 2>&1; then
        printf 'corepack pnpm\n'
        return 0
    fi

    return 1
}

run_pnpm() {
    local pnpm_cmd="$1"
    shift

    if [[ "$pnpm_cmd" == "corepack pnpm" ]]; then
        corepack pnpm "$@"
    else
        "$pnpm_cmd" "$@"
    fi
}

discover_node_projects() {
    local worktree_path="$1"
    local abs_path
    local rel_dir

    while IFS= read -r abs_path; do
        rel_dir="$(dirname "${abs_path#$worktree_path/}")"
        if [[ "$rel_dir" == "." ]]; then
            rel_dir=""
        fi

        if [[ -f "$worktree_path/${rel_dir:+$rel_dir/}pnpm-lock.yaml" || -f "$worktree_path/${rel_dir:+$rel_dir/}package-lock.json" || -f "$worktree_path/${rel_dir:+$rel_dir/}yarn.lock" ]]; then
            printf '%s\n' "${rel_dir:-.}"
        fi
    done < <(
        find "$worktree_path" \
            \( -type d \( -name .git -o -name .venv -o -name node_modules -o -name .next -o -name dist -o -name build -o -name coverage -o -name htmlcov -o -name __pycache__ \) -prune \) \
            -o \( -type f -name 'package.json' -print \) \
            | sort
    )
}

sync_node_project() {
    local worktree_path="$1"
    local bare_root="$2"
    local project_rel="$3"
    local project_dir
    local shared_store="$bare_root/shared/pnpm-store"
    local pnpm_cmd

    if [[ "$project_rel" == "." ]]; then
        project_dir="$worktree_path"
    else
        project_dir="$worktree_path/$project_rel"
    fi

    [[ -f "$project_dir/package.json" ]] || return 0
    ensure_dir "$shared_store"

    if [[ "${WORKTREE_SYNC_SKIP_INSTALL:-0}" == "1" ]]; then
        print_warning "Skipping Node install in ${project_rel:-.} because WORKTREE_SYNC_SKIP_INSTALL=1"
        return 0
    fi

    pnpm_cmd="$(detect_pnpm_cmd || true)"
    if [[ -z "$pnpm_cmd" ]]; then
        print_warning "pnpm is unavailable. Node sync skipped for ${project_rel:-.}."
        return 0
    fi

    print_status "Synchronizing Node dependencies in ${project_rel:-.}"
    (
        cd "$project_dir"
        export PNPM_STORE_DIR="$shared_store"
        export npm_config_store_dir="$shared_store"

        if [[ ! -f pnpm-lock.yaml && ( -f yarn.lock || -f package-lock.json ) ]]; then
            run_pnpm "$pnpm_cmd" import
        fi

        if [[ -f pnpm-lock.yaml ]]; then
            run_pnpm "$pnpm_cmd" install --frozen-lockfile
        else
            run_pnpm "$pnpm_cmd" install --no-frozen-lockfile
        fi
    )
}

sync_node_projects() {
    local worktree_path="$1"
    local bare_root="$2"
    local project_rel

    if [[ "${#SYNC_NODE_PROJECTS[@]}" -gt 0 ]]; then
        for project_rel in "${SYNC_NODE_PROJECTS[@]}"; do
            sync_node_project "$worktree_path" "$bare_root" "$project_rel"
        done
        return 0
    fi

    if [[ "$SYNC_DISABLE_NODE_DISCOVERY" == "1" ]]; then
        return 0
    fi

    while IFS= read -r project_rel; do
        [[ -n "$project_rel" ]] || continue
        sync_node_project "$worktree_path" "$bare_root" "$project_rel"
    done < <(discover_node_projects "$worktree_path")
}

print_summary() {
    local worktree_path="$1"
    local bare_root="$2"

    cat << EOF

Ready in: $worktree_path

Shared env files:
  $bare_root/shared/env

Shared Python virtualenvs:
  $bare_root/shared/venv

Shared pnpm store:
  $bare_root/shared/pnpm-store

Shared runtime paths:
  $bare_root/shared

Run your usual backend/frontend commands from the synchronized worktree.
EOF
}

sync_one_worktree() {
    local worktree_path="$1"
    local bare_root="$2"

    worktree_path="$(resolve_abs_path "$worktree_path")"

    if ! git -C "$worktree_path" rev-parse --show-toplevel > /dev/null 2>&1; then
        print_error "Not a valid worktree: $worktree_path"
        return 1
    fi

    print_status "Synchronizing worktree: $worktree_path"
    load_repo_config "$bare_root"
    link_envs "$worktree_path" "$bare_root"
    link_shared_runtime_paths "$worktree_path" "$bare_root"
    sync_poetry_projects "$worktree_path" "$bare_root"
    sync_node_projects "$worktree_path" "$bare_root"
    print_summary "$worktree_path" "$bare_root"
}

list_linked_worktrees() {
    local bare_root="$1"
    git -C "$bare_root" worktree list --porcelain | awk '/^worktree /{print substr($0,10)}'
}

main() {
    local target="${1:-}"
    local start_dir
    local bare_root
    local current_worktree
    local worktree
    local synced=0

    if [[ "$target" == "-h" || "$target" == "--help" ]]; then
        usage
    fi

    start_dir="$(pwd)"
    if [[ -n "$target" ]]; then
        start_dir="$(resolve_abs_path "$target")"
    fi

    bare_root="$(find_bare_root "$start_dir" || true)"
    if [[ -z "$bare_root" ]]; then
        print_error "Could not determine the bare repository root from: $start_dir"
        exit 1
    fi

    current_worktree="$(current_worktree_or_empty "$start_dir")"

    if [[ -n "$target" ]]; then
        sync_one_worktree "$start_dir" "$bare_root"
        exit 0
    fi

    if [[ -n "$current_worktree" ]]; then
        sync_one_worktree "$current_worktree" "$bare_root"
        exit 0
    fi

    if ! git -C "$bare_root" rev-parse --is-bare-repository 2>/dev/null | grep -q "true"; then
        print_error "Current directory is not a worktree and not a bare repository root"
        exit 1
    fi

    while IFS= read -r worktree; do
        if [[ "$worktree" == "$bare_root" ]]; then
            continue
        fi
        sync_one_worktree "$worktree" "$bare_root"
        synced=1
    done < <(list_linked_worktrees "$bare_root")

    if [[ "$synced" -eq 0 ]]; then
        print_warning "No linked worktrees found to synchronize."
    fi
}

main "$@"
